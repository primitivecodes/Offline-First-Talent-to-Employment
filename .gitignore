# ═══════════════════════════════════════════════
# ALU Talent Platform — .gitignore
# ═══════════════════════════════════════════════


# ── SECRETS — never commit these ────────────────
.env
.env.production
.env.local
.env.*.local


# ── DEPENDENCIES — recreated by npm install ─────
node_modules/
backend/node_modules/
frontend/node_modules/


# ── DATABASE — contains real user data ──────────
backend/database.sqlite
backend/database.sqlite-journal
*.sqlite
*.sqlite3


# ── USER UPLOADS — private user content ─────────
backend/uploads/


# ── BUILD OUTPUT — generated, not source code ───
frontend/build/
frontend/dist/
build/
dist/


# ── TEST COVERAGE — auto-generated reports ──────
coverage/
backend/coverage/
frontend/coverage/


# ── LOGS — clutter with no value to others ──────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/


# ── OS FILES — created automatically ────────────
# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ── EDITOR FILES — specific to your machine ─────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace


# ── RUNTIME ─────────────────────────────────────
*.pid
*.seed
*.pid.lock
.npm
```

**Where to put this file:**
```
Offline-First-Talent-to-Employment-Platform/
├── .gitignore          ← goes here, at the root
├── backend/
├── frontend/
└── docker-compose.yml
